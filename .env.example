# Database (MongoDB — primary + cache/session layer)
DATABASE_URL="mongodb://user:pass@localhost:27017/telegram_drive?authSource=admin"

# Auth
JWT_SECRET="your-256-bit-secret"
JWT_REFRESH_SECRET="your-256-bit-refresh-secret"

# Encryption (32-byte hex key = 64 hex chars)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# App
PUBLIC_URL="https://your-domain.com"
NODE_ENV="production"
APP_NAME="Cloudgram"
TELEGRAM_FOLDER_PREFIX="[td]"

# Telegram (optional — for bot-based features)
BOT_TOKEN="optional-telegram-bot-token"
